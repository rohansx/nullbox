CONFIG_IWLMVM=y
# Realtek WiFi
CONFIG_RTW88=y
CONFIG_RTW89=y
# Atheros/Qualcomm
CONFIG_ATH9K=y
CONFIG_ATH10K=y
CONFIG_ATH11K=y

#
# === Storage drivers (built-in, no modules) ===
#
CONFIG_ATA=y
CONFIG_SATA_AHCI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y
CONFIG_SCSI=y
CONFIG_SCSI_MOD=y
CONFIG_BLK_DEV_NVME=y
CONFIG_MMC=y
CONFIG_MMC_BCM2835=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_IPROC=y
CONFIG_USB_STORAGE=y

#
# === USB (for RPi and general hardware) ===
#
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_OHCI_HCD=y

#
# === Serial console (primary debug interface) ===
#
